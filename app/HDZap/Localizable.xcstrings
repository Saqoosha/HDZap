    },
    "No devices found. Tap Scan to search." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイスが見つかりません。「スキャン」をタップして検索してください。"
          }
        }
      }
    },
    "No verification result. The M5Stick may be disconnected — try again." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確認結果が得られませんでした。M5Stick が切断されている可能性があります — もう一度試してください。"
          }
        }
      }
    },
    "No verification result. The M5Stick may be disconnected — try again, or use Restore previous goggle." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確認結果が得られませんでした。M5Stick が切断されている可能性があります — もう一度試すか、「前のゴーグルに戻す」を使用してください。"
          }
        }
      }
    },
    "Normalized: %@" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正規化済み: %@"
          }
        }
      }
    },
    "Pair with a new goggle?" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいゴーグルとペアリングしますか？"
          }
        }
      }
    },
    "Pair with new goggle" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいゴーグルとペアリング"
          }
        }
      }
    },
    "Pairing" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ペアリング"
          }
        }
      }
    },
    "Pairing works — lap times will appear on this goggle." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ペアリング成功 — ラップタイムはこのゴーグルに表示されます。"
          }
        }
      }
    },
    "Parsed: %@" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解析結果: %@"
          }
        }
      }
    },
    "Press Bind on the TX to broadcast its UID. The TX's existing goggle binding is unaffected." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TX の Bind を押して UID をブロードキャストしてください。TX とゴーグルの既存のバインドには影響しません。"
          }
        }
      }
    },
    "Put your goggle in bind mode (ELRS menu → Bind), then tap Pair below. The M5Stick will switch to a fresh pairing ID and broadcast it to the goggle in one step." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ゴーグルをバインドモード(ELRS メニュー → Bind)にしてから、下の「ペアリング」をタップしてください。M5Stick が新しいペアリング ID に切り替わり、その ID をゴーグルへ一度に送信します。"
          }
        }
      }
    },
    "Race" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レース"
          }
        }
      }
    },
    "Race time" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レース時間"
