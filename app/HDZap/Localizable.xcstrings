      }
    },
    "Reset" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リセット"
          }
        }
      }
    },
    "Restore previous goggle" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前のゴーグルに戻す"
          }
        }
