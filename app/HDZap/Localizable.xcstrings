        }
      }
    },
    "%lld%% · Critical — press button on device to silence" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld%% · 危険 — デバイスのボタンを押すとサイレントにできます"
          }
        }
      }
    },
    "%lld%% · Low (silenced)" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld%% · 残量低下(サイレント)"
          }
