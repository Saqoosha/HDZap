    "Connect an M5Stick bridge to mirror lap times on your goggle OSD.": {
      "comment": "Settings → Device section footer shown when the Use bridge toggle is OFF, explaining what the bridge is for.",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "M5Stick ブリッジを接続するとラップタイムをゴーグルの OSD に表示できます。"
          }
        }
      }
    },
    "Connect to the M5Stick to preview on the goggle.": {
      "comment": "OSD layout editor preview footnote shown when no M5Stick is connected.",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "M5Stick に接続するとゴーグルでプレビューできます。"
