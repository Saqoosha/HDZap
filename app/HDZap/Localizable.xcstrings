  "strings" : {
    "—" : {
      "comment" : "Battery caption when no battery frame has arrived yet.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "—"
          }
        }
      }
    },
    "%lld%%" : {
