# Copy to .env and fill in the keys you have. Missing keys → that provider is skipped.
#
# IMPORTANT: this tool calls live paid APIs. If your shell rc exports e.g. OPENAI_API_KEY,
# the tool WILL pick it up and bill you even without a .env file. To explicitly disable
# a provider whose key is in your shell, set the variable to empty in this file:
#     OPENAI_API_KEY=
# (the empty assignment overrides the shell-exported value because we load_dotenv(override=True))

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Cloud TTS (Chirp 3 HD) — needs service-account JSON path
# https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=

# Google Gemini API (separate from Cloud TTS) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AWS Polly — uses default boto3 chain (env / ~/.aws/credentials / IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1

# fish.audio — https://fish.audio/go-api/
FISH_AUDIO_API_KEY=

# Cartesia — https://play.cartesia.ai/
CARTESIA_API_KEY=

# Inworld — https://platform.inworld.ai/
INWORLD_API_KEY=

# Murf — https://murf.ai/api
MURF_API_KEY=

# xAI Grok — https://console.x.ai/
XAI_API_KEY=
